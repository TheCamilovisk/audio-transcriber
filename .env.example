# Telegram bot token from @BotFather (required)
TELEGRAM_BOT_TOKEN=

# Base URL of the remote transcription REST API
TRANSCRIPTION_API_BASE_URL=http://localhost:8000

# Per-HTTP-call timeout (seconds) for POST/GET requests
TRANSCRIPTION_REQUEST_TIMEOUT=30

# Seconds to sleep between job-status polls
TRANSCRIPTION_POLL_INTERVAL=2

# Max total seconds to wait for a job to reach a terminal status
TRANSCRIPTION_POLL_TIMEOUT=300
