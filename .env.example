# Telegram bot token from @BotFather (required)
TELEGRAM_BOT_TOKEN=

# Whisper model size: tiny | base | small | medium | large-v3 | turbo
WHISPER_MODEL=turbo

# Device: cpu | cuda | auto  (auto -> cuda if available, else cpu)
DEVICE=cpu

# Optional: override compute type (default float16 on cuda, int8 on cpu)
# COMPUTE_TYPE=int8

# Batch size for the batched inference pipeline
BATCH_SIZE=16
